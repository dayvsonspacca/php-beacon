{
    "name": "dayvsonspacca/php-beacon",
    "description": "Monorepo for the Beacon PHP packages (contracts, guzzle-client)",
    "type": "project",
    "authors": [
        {
            "name": "Dayvson Spacca",
            "email": "spacca.dayvson@gmail.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "Beacon\\Guzzle\\": "packages/guzzle-client/src/",
            "Beacon\\": "packages/contracts/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Beacon\\Guzzle\\Tests\\": "packages/guzzle-client/tests/",
            "Beacon\\Tests\\": "packages/contracts/tests/"
        }
    },
    "require": {
        "php-standard-library/type": "^6.2",
        "php-standard-library/url": "^6.2",
        "php-standard-library/json": "^6.2",
        "guzzlehttp/guzzle": "^7.14"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.2",
        "carthage-software/mago": "^1.43.0"
    },
    "scripts": {
        "test": "phpunit",
        "lint": "mago lint",
        "format": "mago format",
        "format:check": "mago format --check",
        "analyze": "mago analyze",
        "check": [
            "@format:check",
            "@lint",
            "@analyze",
            "@test"
        ]
    }
}
