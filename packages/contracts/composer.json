{
    "name": "dayvsonspacca/beacon-contracts",
    "description": "Contracts (client interface and value objects) for the Beacon event platform",
    "type": "library",
    "keywords": ["beacon", "contracts", "events", "pubsub"],
    "authors": [
        {
            "name": "Dayvson Spacca",
            "email": "spacca.dayvson@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.4",
        "php-standard-library/type": "^6.2"
    },
    "suggest": {
        "dayvsonspacca/beacon-guzzle-client": "Ready-to-use Guzzle implementation of the Beacon contracts"
    },
    "autoload": {
        "psr-4": {
            "Beacon\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Beacon\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^13.2",
        "carthage-software/mago": "^1.43.0"
    },
    "scripts": {
        "test": "phpunit",
        "lint": "mago lint",
        "format": "mago format",
        "format:check": "mago format --check",
        "analyze": "mago analyze",
        "check": [
            "@format:check",
            "@lint",
            "@analyze",
            "@test"
        ]
    }
}
